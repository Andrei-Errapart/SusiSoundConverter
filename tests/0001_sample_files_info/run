#!/usr/bin/env bash
# Download sample files and run the converter in info-only mode.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
TEST_DIR="$(cd "$(dirname "$0")" && pwd)"
DOWNLOAD_DIR="$TEST_DIR/downloads"
CONVERTER="$REPO_ROOT/SusiSoundConverter"

if [[ ! -x "$CONVERTER" ]]; then
    echo "ERROR: $CONVERTER not found or not executable"
    exit 1
fi

mkdir -p "$DOWNLOAD_DIR"

# Extract URLs from sample-input-files.yaml
urls=$(grep -oP 'https?://\S+' "$REPO_ROOT/tests/sample-input-files.yaml")

for url in $urls; do
    # Extract file path from the file= query parameter
    file_path=$(echo "$url" | grep -oP 'file=\K.*')
    download_url="https://www.d-i-e-t-z.de/$file_path"
    filename=$(basename "$file_path")
    zip_file="$DOWNLOAD_DIR/$filename"
    extract_dir="$DOWNLOAD_DIR/${filename%.*}"

    # Download if not already present
    if [[ ! -f "$zip_file" ]]; then
        echo "Downloading $filename..."
        curl -fsSL -o "$zip_file" "$download_url"
    fi

    # Extract if not already done
    if [[ ! -d "$extract_dir" ]]; then
        echo "Extracting $filename..."
        mkdir -p "$extract_dir"
        unzip -q -o "$zip_file" -d "$extract_dir"
    fi

    # Run converter in info-only mode on all extracted files
    echo "Running converter on $filename contents..."
    find "$extract_dir" -type f | while read -r f; do
        echo "  $f"
        "$CONVERTER" -i "$f"
    done
done

echo "Test passed."
