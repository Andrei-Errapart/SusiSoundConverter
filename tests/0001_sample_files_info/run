#!/usr/bin/env bash
# Run infosound on each sound file in test_data/ and compare output to expected.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
TEST_DIR="$(cd "$(dirname "$0")" && pwd)"
EXPECTED_DIR="$TEST_DIR/expected"
INFOSOUND="$REPO_ROOT/zig-out/bin/infosound"

if [[ ! -x "$INFOSOUND" ]]; then
    echo "ERROR: $INFOSOUND not found — run 'zig build' first"
    exit 1
fi

if [[ ! -d "$EXPECTED_DIR" ]]; then
    echo "ERROR: $EXPECTED_DIR not found"
    exit 1
fi

# Strip the "=== <path> ===" header line (contains machine-specific path)
# and any trailing blank lines.
normalize() {
    sed '1{/^=== .* ===$/d}' | sed -e :a -e '/^\n*$/{$d;N;ba}'
}

failed=0
tested=0

for sound_file in "$REPO_ROOT"/test_data/*.DS3 "$REPO_ROOT"/test_data/*.DX4 "$REPO_ROOT"/test_data/*.DS6 "$REPO_ROOT"/test_data/*.DSU; do
    [[ -f "$sound_file" ]] || continue

    base="$(basename "$sound_file")"
    expected="$EXPECTED_DIR/${base}.expected"

    if [[ ! -f "$expected" ]]; then
        echo "SKIP $base (no expected file)"
        continue
    fi

    tested=$((tested + 1))

    actual=$("$INFOSOUND" "$sound_file" 2>&1) || true

    if diff -u <(normalize < "$expected") <(echo "$actual" | normalize) > /dev/null 2>&1; then
        echo "OK   $base"
    else
        echo "FAIL $base"
        diff -u <(normalize < "$expected") <(echo "$actual" | normalize) || true
        failed=$((failed + 1))
    fi
done

echo ""
echo "$tested tested, $failed failed"
[[ $failed -eq 0 ]]
